---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const currentPath = Astro.url.pathname;
const lang = 'id';

const title = 'Mari Terhubung & Belajar Bersama - Syaiful Anam';
const description = 'Terhubung dengan saya untuk diskusi tentang teknologi, bisnis, AI, dan potensi kolaborasi. Mari bangun sesuatu yang luar biasa bersama.';

// Social links and contact info dalam bahasa Indonesia
const socialLinks = [
	{
		name: 'LinkedIn',
		url: 'https://linkedin.com/in/syaifulanam',
		icon: '💼',
		description: 'Jaringan profesional dan kolaborasi bisnis'
	},
	{
		name: 'GitHub',
		url: 'https://github.com/syanampro',
		icon: '💻',
		description: 'Proyek open source dan kontribusi kode'
	},
	{
		name: 'Twitter/X',
		url: 'https://twitter.com/syanampro',
		icon: '🐦',
		description: 'Pemikiran harian tentang tech, AI, dan pembelajaran berkelanjutan'
	},
	{
		name: 'Instagram',
		url: 'https://instagram.com/syanampro',
		icon: '📸',
		description: 'Dibalik layar perjalanan wirausaha saya'
	},
	{
		name: 'Telegram',
		url: 'https://t.me/syanampro',
		icon: '💬',
		description: 'Chat cepat dan diskusi teknologi'
	}
];

// Topics I'm interested in discussing
const discussionTopics = [
	'Pengembangan dan otomasi berbasis AI',
	'Arsitektur dan skalabilitas B2B SaaS',
	'Implementasi teknologi di industri tradisional',
	'Praktik terbaik pengembangan full-stack',
	'Strategi DevOps dan deployment cloud',
	'Membangun dan menskalakan tim remote',
	'Pembelajaran berkelanjutan dan pengembangan skill',
	'Kewirausahaan dan ventura teknologi'
];
---

<Layout title={title} description={description} lang={lang}>
	<div class="container">
		<Header currentPath={currentPath} lang={lang} />

		<main class="main-content" >
			<div class="connect-content">
				<h1 style="text-align: center;">Mari Terhubung & Belajar Bersama</h1>

				<div class="intro-section">
					<p>
						Saya selalu bersemangat untuk terhubung dengan sesama builder, entrepreneur, dan teknologi enthusiasts. Baik Anda ingin mendiskusikan implementasi AI, berbagi insight tentang software B2B, atau mengeksplorasi potensi kolaborasi, saya siap untuk percakapan yang bermakna.
					</p>
				</div>

				<div class="contact-methods">
					<h2 style="text-align: center; margin: 32px 0 16px 0;">Cara Menghubungi Saya</h2>

					<div class="contact-methods-grid">
						<div class="contact-card">
							<h3>Email</h3>
							<div class="contact-email">
								<a href="mailto:iam@syanam.pro">iam@syanam.pro</a>
							</div>
							<p class="contact-description">Untuk percakapan pribadi atau pertanyaan umum</p>
						</div>

						<div class="contact-card">
							<h3>WhatsApp</h3>
							<div class="contact-email">
								<a href="https://wa.me/6285156858298?text=Halo+Syaiful+Anam,+saya+tertarik+untuk+diskusi+bisnis+dengan+Digital360" target="_blank" rel="noopener noreferrer">0851-5685-8298</a>
							</div>
							<p class="contact-description">Digital360 - Untuk bisnis dan kerjasama</p>
						</div>
					</div>

					<p style="text-align: center; font-size: 0.875rem; color: var(--color-text-secondary); font-style: italic; margin-top: 16px;">
						Jika kamu menghubungi via email yang tertera di halaman ini, sangat disarankan untuk encrypt email yang kamu kirimkan.
						Informasi PGP Key ada di bawah ini.
					</p>
				</div>

				<div class="pgp-section">
					<h2 style="text-align: center; margin: 32px 0 16px 0;">Security Key</h2>

					<div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; padding: 24px; margin-bottom: 16px;">
						<div style="font-family: monospace; font-size: 0.875rem; line-height: 1.8;">
							<div style="display: grid; grid-template-columns: 120px 1fr; gap: 8px;">
								<strong>Name:</strong>
								<div>Syaiful Anam</div>

								<strong>Email:</strong>
								<div>iam@syanam.pro</div>

								<strong>Key Type:</strong>
								<div>ECC (Elliptic Curve Cryptography)</div>

								<strong>Key Size:</strong>
								<div>384 bits</div>
							</div>
						</div>
					</div>

					<div class="monospace-key" style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; padding: 16px; font-family: monospace; font-size: 0.75rem; line-height: 1.5; word-break: break-all; white-space: pre-wrap; overflow-x: auto;">-----BEGIN PGP PUBLIC KEY BLOCK-----

